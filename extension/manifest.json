{
  "manifest_version": 3,
  "name": "WorldCupWatchPlace",
  "version": "0.1.0",
  "description": "Find reliable places nearby to watch World Cup matches with other fans.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "sidePanel", "storage", "tabs", "scripting", "geolocation"],
  "host_permissions": [
    "https://www.google.com/*",
    "https://maps.google.com/*",
    "http://127.0.0.1:8788/*",
    "https://worldcupwatchplace-api.onrender.com/*"
  ],
  "action": {
    "default_title": "WorldCupWatchPlace",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.com/maps*",
        "https://maps.google.com/*"
      ],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
